# Supabase (Project Settings -> API)
VITE_SUPABASE_URL=
# Publishable key (sb_publishable_...) — безопасен для frontend-бандла.
VITE_SUPABASE_ANON_KEY=

# Secret key (sb_secret_...) используется ТОЛЬКО на сервере (Edge Functions),
# никогда не должен попадать в frontend-бандл / VITE_-переменные.
SUPABASE_SECRET_KEY=

# Telegram
# Токен бота, выданный BotFather (используется на сервере для проверки initData и т.п.)
TELEGRAM_BOT_TOKEN=
# Username бота без @ (используется на frontend для ссылок/диплинков)
VITE_TELEGRAM_BOT_USERNAME=
